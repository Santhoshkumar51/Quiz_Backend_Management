# Copy this file to .env for local use .
# On your deploy host (Render, etc.), set these as real environment variables.

# Used to sign JWT admin login tokens. Set a long random string in production.
SECRET_KEY=change-this-to-a-long-random-string

# If all three are set AND no admin exists yet, an admin account is auto-created
# on startup. This is how you provision your admin login on a host with no shell
# access. Leave unset locally and use `python -m app.create_admin` instead.
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
